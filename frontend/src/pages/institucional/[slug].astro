---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { directus, safeRequest, readItems, getAllPaginasInstitucionais } from '../../lib/directus';
import type { PaginaInstitucional } from '../../schemas/directus';

export async function getStaticPaths() {
  const paginas = await getAllPaginasInstitucionais();
  return paginas.map((p: PaginaInstitucional) => ({
    params: { slug: p.slug },
    props: { pagina: p },
  }));
}

const { slug } = Astro.params;
const pagina = await safeRequest(
  directus.request(readItems('paginas_institucionais', {
    filter: { slug: { _eq: slug }, status: { _eq: 'published' } },
    limit: 1,
  })),
  []
);

const item = pagina?.[0] ?? null;
if (!item) return Astro.redirect('/404');

const allPaginas = await getAllPaginasInstitucionais();
const currentIndex = allPaginas.findIndex((p) => p.slug === slug);
const prev = currentIndex > 0 ? allPaginas[currentIndex - 1] : null;
const next = currentIndex < allPaginas.length - 1 ? allPaginas[currentIndex + 1] : null;
---

<Layout title={`${item.titulo} — Institucional`} description={`${item.titulo} - Fundação de Cultura Elias Mansour`}>
  <div class="max-w-container-max-width mx-auto px-gutter py-8">
    <PageHero title={item.titulo}
      description={slug === 'quem-somos' ? 'História, objetivos, legislação e visão de futuro da Fundação de Cultura Elias Mansour.'
        : slug === 'concultura' ? 'O Conselho Estadual de Cultura do Acre — história, composição e atribuições.'
        : slug === 'presidencia' ? 'Conheça a presidência da Fundação de Cultura Elias Mansour e sua trajetória.'
        : undefined}
      breadcrumbLabel="Institucional" />
  </div>

  <section class="max-w-container-max-width mx-auto px-gutter pb-section-gap">
    <div class="flex flex-col lg:flex-row gap-12">
      <article class="flex-1 min-w-0">
        {item.conteudo ? (
          <div class="prose prose-green max-w-none prose-headings:font-display prose-a:text-secondary prose-img:rounded-xl prose-h2:text-headline-md prose-h2:font-display prose-h2:text-primary prose-h3:text-headline-sm prose-h3:font-display prose-h3:text-primary prose-p:text-body-lg prose-p:leading-relaxed prose-p:text-on-surface-variant prose-strong:text-on-surface prose-ul:text-body-lg prose-li:marker:text-primary">
            <Fragment set:html={item.conteudo} />
          </div>
        ) : slug !== 'presidencia' ? (
          <div class="text-center py-20">
            <span class="material-symbols-outlined text-5xl text-outline mb-4">description</span>
            <p class="text-body-lg text-on-surface-variant">Conteúdo em atualização.</p>
          </div>
        ) : null}

        {slug === 'quem-somos' && (
          <>
            <section class="mt-16">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-surface-container-low rounded-2xl p-8 border border-outline-variant/20 hover:shadow-md transition-shadow duration-300">
                  <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-5">
                    <span class="material-symbols-outlined text-2xl text-primary">visibility</span>
                  </div>
                  <h3 class="font-headline-md text-headline-md text-primary mb-3">Missão</h3>
                  <p class="text-body-md text-on-surface-variant leading-relaxed">Fomentar, proteger e difundir as manifestações culturais, promovendo a cidadania, a inclusão social e o desenvolvimento sustentável por meio da arte e do patrimônio cultural acreano.</p>
                </div>
                <div class="bg-surface-container-low rounded-2xl p-8 border border-outline-variant/20 hover:shadow-md transition-shadow duration-300">
                  <div class="w-14 h-14 rounded-2xl bg-secondary/10 flex items-center justify-center mb-5">
                    <span class="material-symbols-outlined text-2xl text-secondary">flag</span>
                  </div>
                  <h3 class="font-headline-md text-headline-md text-primary mb-3">Visão</h3>
                  <p class="text-body-md text-on-surface-variant leading-relaxed">Ser referência nacional na gestão de políticas culturais, reconhecida pela excelência na valorização da diversidade, na preservação da memória e no estímulo à economia criativa da Amazônia.</p>
                </div>
              </div>
            </section>
          </>
        )}

        {slug === 'concultura' && (
          <>
            <section class="mt-16">
              <h2 class="font-display text-headline-md text-primary mb-8">Linha do Tempo</h2>
              <div class="relative pl-8 border-l-2 border-primary/30 space-y-10">
                {[
                  { year: '1989', title: 'Criação', desc: 'Previsto no art. 193 da Constituição Estadual, com competência de contribuir com a política estadual de cultura.' },
                  { year: '2005', title: 'Regulamentação', desc: 'Decreto nº 12.616 de 09/08/2005 estabelece atribuições, composição e funcionamento.' },
                  { year: '2006', title: 'Primeira Composição', desc: 'Eleição e posse dos primeiros 22 membros (11 titulares e 11 suplentes).' },
                  { year: '2020', title: 'Reforma', desc: 'Decreto nº 6.369 altera a composição para 16 membros (8 titulares e 8 suplentes).' },
                ].map((m) => (
                  <div class="relative">
                    <div class="absolute -left-[calc(2rem+7px)] top-1 w-3.5 h-3.5 rounded-full bg-primary border-2 border-surface" />
                    <span class="inline-block px-3 py-1 bg-primary/10 text-primary rounded-full text-label-sm font-semibold mb-2">{m.year}</span>
                    <h3 class="font-label-lg text-label-lg text-on-surface mb-1">{m.title}</h3>
                    <p class="text-body-md text-on-surface-variant">{m.desc}</p>
                  </div>
                ))}
              </div>
            </section>

            <section class="mt-16">
              <div class="bg-gradient-to-br from-primary/5 to-primary-container/10 rounded-3xl p-8 md:p-12 border border-primary/10">
                <div class="flex flex-col md:flex-row items-center gap-8">
                  <div class="w-40 h-40 md:w-48 md:h-48 rounded-full bg-primary/10 flex items-center justify-center shrink-0 border-4 border-primary/20 overflow-hidden">
                    <img src="/api/file/a8eee571-23fe-42f1-a5f0-5161e08edb28" alt="Manoel Coracy Saboia Dias" class="w-full h-full object-cover object-top" />
                  </div>
                  <div>
                    <span class="inline-block px-3 py-1 bg-primary text-on-primary rounded-full text-label-sm font-semibold mb-3">Presidente do Conselho</span>
                    <h3 class="font-display text-display-sm text-primary">Manoel Coracy Saboia Dias</h3>
                    <p class="text-label-lg text-outline mt-1">Presidente do Concultura/AC</p>
                    <p class="text-body-md text-on-surface-variant mt-4 leading-relaxed">
                      Presidente do Conselho Estadual de Cultura do Acre, conduzindo as atividades do colegiado na formulação e controle das políticas culturais do Estado.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <section class="mt-16">
              <div class="bg-gradient-to-br from-primary/5 to-primary-container/10 rounded-3xl p-8 md:p-10 border border-primary/10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div>
                    <div class="flex items-center gap-3 mb-4">
                      <span class="material-symbols-outlined text-2xl text-primary">location_on</span>
                      <h3 class="font-display text-headline-md text-primary">Nova Sede</h3>
                    </div>
                    <p class="text-body-md text-on-surface-variant leading-relaxed">
                      O Conselho Estadual de Cultura está de casa nova. Estamos funcionando no <strong>Espaço Cultura Viva</strong>, localizado no Calçadão da Gameleira, Segundo Distrito.
                    </p>
                  </div>
                  <div>
                    <div class="flex items-center gap-3 mb-4">
                      <span class="material-symbols-outlined text-2xl text-primary">event</span>
                      <h3 class="font-display text-headline-md text-primary">Reuniões</h3>
                    </div>
                    <p class="text-body-md text-on-surface-variant leading-relaxed mb-3">
                      <strong>Últimas quartas-feiras de cada mês, a partir das 15h.</strong>
                    </p>
                    <p class="text-body-md text-primary italic flex items-center gap-2">
                      <span class="material-symbols-outlined">celebration</span>
                      Você é nosso convidado. Venha nos fazer uma visita!
                    </p>
                  </div>
                </div>
              </div>
            </section>
          </>
        )}

        {slug === 'presidencia' && (
          <>
            <section>
              <div class="bg-gradient-to-br from-primary/5 to-primary-container/10 rounded-3xl p-8 md:p-12 border border-primary/10">
                <div class="flex flex-col md:flex-row items-center gap-8">
                  <div class="w-40 h-40 md:w-48 md:h-48 rounded-full bg-primary/10 flex items-center justify-center shrink-0 border-4 border-primary/20 overflow-hidden">
                    <img src="/api/file/7303de3b-c2c1-4849-9c38-eff9b51e02d1" alt="Matheus Gomes" class="w-full h-full object-cover object-top" />
                  </div>
                  <div>
                    <span class="inline-block px-3 py-1 bg-primary text-on-primary rounded-full text-label-sm font-semibold mb-3">Presidente</span>
                    <h3 class="font-display text-display-sm text-primary">Matheus Gomes</h3>
                    <p class="text-label-lg text-outline mt-1">Presidente da Fundação de Cultura Elias Mansour (FEM)</p>
                    <p class="text-body-md text-on-surface-variant mt-4 leading-relaxed">
                                            Historiador de formação, assumiu a presidência da Fundação de Cultura Elias Mansour em abril de 2026, nomeado pelo governador Gladson Cameli, dando continuidade à gestão de Minoru Kinpara. Sua gestão tem como prioridades ampliar o acesso à cultura, fortalecer o Sistema Estadual de Cultura e valorizar a identidade amazônica. Antes de liderar a FEM, atuou como diretor da instituição.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <section class="mt-16">
              <h2 class="font-display text-headline-md text-primary mb-8">Presidentes Anteriores</h2>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {[
                  { nome: 'Minoru Kinpara', periodo: 'Jan/2023 — Abr/2026', foto: 'fbbd0487-d682-427d-8048-7dc41457237e' },
                ].map((ep) => {
                  const iniciais = ep.nome.split(' ').map((p) => p[0]).join('').slice(0, 2).toUpperCase();
                  return (
                    <div class="bg-surface-container-low rounded-2xl p-6 text-center border border-outline-variant/20 hover:-translate-y-1 transition-all duration-300">
                      <div class="w-32 h-32 rounded-full bg-surface-container-high flex items-center justify-center mx-auto mb-4 overflow-hidden">
                        {ep.foto ? (
                          <img src={`/api/file/${ep.foto}`} alt={ep.nome} class="w-full h-full object-cover object-top" />
                        ) : (
                          <span class="font-display text-headline-md text-on-surface-variant">{iniciais}</span>
                        )}
                      </div>
                      <h4 class="font-label-md text-label-md text-on-surface mb-1">{ep.nome}</h4>
                      <p class="text-label-sm text-outline whitespace-nowrap">{ep.periodo}</p>
                    </div>
                  );
                })}
              </div>
              <p class="text-center text-body-md text-outline mt-8 italic">
        Em breve, fotos e biografias completas de todos os ex-presidentes.
              </p>
            </section>
          </>
        )}

        <div class="flex items-center justify-between mt-16 pt-8 border-t border-outline-variant/20">
          {prev ? (
            <a href={`/institucional/${prev.slug}`} class="group flex items-center gap-3 text-on-surface-variant hover:text-primary transition-colors">
              <span class="material-symbols-outlined group-hover:-translate-x-1 transition-transform">arrow_back</span>
              <div class="text-left">
                <div class="text-label-sm text-outline">Anterior</div>
                <div class="font-label-md text-label-md">{prev.titulo}</div>
              </div>
            </a>
          ) : <div />}
          {next ? (
            <a href={`/institucional/${next.slug}`} class="group flex items-center gap-3 text-on-surface-variant hover:text-primary transition-colors text-right">
              <div>
                <div class="text-label-sm text-outline">Próximo</div>
                <div class="font-label-md text-label-md">{next.titulo}</div>
              </div>
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          ) : <div />}
        </div>
      </article>

      {allPaginas.length > 1 && (
        <aside class="lg:w-72 shrink-0">
          <div class="sticky top-[120px] bg-surface-container-lowest rounded-2xl border border-outline-variant/20 p-6 shadow-sm">
            <h3 class="font-label-md text-label-md text-outline uppercase tracking-wider mb-5">Nesta seção</h3>
            <ul class="flex flex-col gap-1">
              {allPaginas.map((p) => {
                const isActive = p.slug === slug;
                return (
                  <li>
                    <a
                      href={`/institucional/${p.slug}`}
                      class={`block px-4 py-2.5 rounded-xl font-label-md text-label-md transition-all ${
                        isActive
                          ? 'bg-primary text-on-primary font-medium shadow-sm'
                          : 'text-on-surface-variant hover:bg-surface-container hover:text-primary'
                      }`}
                    >
                      {p.titulo}
                    </a>
                  </li>
                );
              })}
            </ul>
            <div class="mt-6 pt-5 border-t border-outline-variant/20">
              <a href="/institucional" class="flex items-center gap-2 text-label-md text-primary hover:underline">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                Visão geral
              </a>
            </div>
          </div>
        </aside>
      )}
    </div>
  </section>
</Layout>
