---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { obterTodasPaginasInstitucionais } from '../../lib/directus';

const paginas = await obterTodasPaginasInstitucionais();

const stats = [
  { value: '42', label: 'Espaços Culturais', icon: 'location_city' },
  { value: '26', label: 'Municípios Atendidos', icon: 'map' },
  { value: '1999', label: 'Fundação', icon: 'calendar_today' },
  { value: '8', label: 'Bibliotecas', icon: 'library_books' },
];

const areas = [
  { icon: 'museum', title: 'Patrimônio Histórico', desc: 'Preservação e gestão de museus, memoriais e sítios históricos', color: 'bg-primary/10 text-primary' },
  { icon: 'payments', title: 'Fomento à Cultura', desc: 'Editais, leis de incentivo e financiamento a projetos culturais', color: 'bg-secondary/10 text-secondary' },
  { icon: 'library_books', title: 'Sistema de Bibliotecas', desc: 'Gestão da leitura, literatura e bibliotecas públicas', color: 'bg-tertiary/10 text-tertiary' },
  { icon: 'stadium', title: 'Espaços Culturais', desc: 'Teatros, centros culturais, galerias e espaços de memória mantidos pelo Estado.', color: 'bg-primary/10 text-primary' },
];
---

<Layout title="Institucional" description="A Fundação de Cultura Elias Mansour - FEM, Governo do Estado do Acre">
  <div class="max-w-container-max-width mx-auto px-gutter py-8">
    <PageHero title="A Instituição" description="Conheça a Fundação de Cultura Elias Mansour — sua história, estrutura e atuação na promoção da cultura acreana." breadcrumbLabel="Institucional" />

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-section-gap">
      {stats.map((s) => (
        <div class="bg-surface-container-lowest rounded-2xl p-6 text-center shadow-sm border border-outline-variant/20">
          <span class="material-symbols-outlined text-3xl text-primary mb-2" aria-hidden="true">{s.icon}</span>
          <div class="font-display text-display-md text-primary">{s.value}</div>
          <div class="font-label-md text-label-md text-on-surface-variant mt-1">{s.label}</div>
        </div>
      ))}
    </div>

    <section class="mb-section-gap">
      <h2 class="font-display text-display-sm md:text-display-md text-primary mb-6">Sobre a FEM</h2>
      <div class="max-w-3xl space-y-5 text-body-lg leading-relaxed text-on-surface-variant">
        <p>Criada por meio da Lei Complementar nº 61, de 13 de janeiro de 1999, a Fundação de Cultura Elias Mansour (FEM) é a entidade da administração pública estadual responsável por formular, coordenar, executar e fortalecer as políticas culturais do Governo do Estado do Acre.</p>
        <p>Atua na promoção, preservação e valorização do patrimônio histórico, artístico e cultural acreano, tendo vinculados à sua estrutura o Conselho Estadual de Cultura e o Conselho de Patrimônio Histórico e Cultural.</p>
      </div>
    </section>

    <section class="mb-section-gap">
      <h2 class="font-display text-display-sm md:text-display-md text-primary mb-8 text-center">Áreas de Atuação</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {areas.map((a) => (
          <div class="bg-surface-container-lowest rounded-2xl p-8 shadow-sm border border-outline-variant/20 hover:-translate-y-1 transition-all duration-300">
            <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-5 ${a.color}`}>
              <span class="material-symbols-outlined text-2xl" aria-hidden="true">{a.icon}</span>
            </div>
            <h3 class="font-label-lg text-label-lg text-on-surface mb-2">{a.title}</h3>
            <p class="text-body-md text-on-surface-variant leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-section-gap">
      <h2 class="font-display text-display-sm md:text-display-md text-primary mb-8 text-center">Navegue pelas Páginas</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {paginas.map((p, i) => {
          const icons = ['account_balance', 'description', 'gavel', 'history', 'contact_support'];
          const icon = icons[i % icons.length];
          return (
            <a href={`/institucional/${p.slug}`} class="group bg-surface-container-lowest rounded-2xl p-8 shadow-sm border border-outline-variant/20 hover:-translate-y-1 hover:shadow-md transition-all duration-300">
              <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-2xl" aria-hidden="true">{icon}</span>
              </div>
              <h3 class="font-label-lg text-label-lg text-on-surface mb-2">{p.titulo}</h3>
              <p class="text-body-md text-on-surface-variant line-clamp-2 leading-relaxed">Saiba mais sobre {p.titulo.toLowerCase()} da Fundação de Cultura Elias Mansour.</p>
              <span class="inline-flex items-center gap-1 mt-4 text-label-md text-primary font-medium">
                Acessar <span class="material-symbols-outlined text-[16px]" aria-hidden="true">arrow_forward</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</Layout>
