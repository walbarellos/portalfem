---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import CardNoticia from '../components/CardNoticia.astro';

import Pagination from '../components/Pagination.astro';
import { safeRequest, directus, readItems } from '../lib/directus';

const pageSize = 9;
const currentPage = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const offset = (currentPage - 1) * pageSize;
const activeCategoria = Astro.url.searchParams.get('categoria') || 'todas';

const filterBase: Record<string, unknown> = { status: { _eq: 'published' } };
if (activeCategoria !== 'todas') {
  filterBase.categoria = { _eq: activeCategoria };
}

const noticias = await safeRequest(
  directus.request(readItems('noticias', {
    filter: filterBase,
    sort: ['-data_publicacao'],
    limit: pageSize,
    offset,
    fields: ['id', 'titulo', 'resumo', 'data_publicacao', 'imagem_destaque', 'autor', 'categoria'],
  })),
  []
);

const allNoticias = await safeRequest(
  directus.request(readItems('noticias', {
    filter: filterBase,
    fields: ['id'],
  })),
  []
);

const total = allNoticias.length;
const totalPages = Math.ceil(total / pageSize);

const allForFeatured = await safeRequest(
  directus.request(readItems('noticias', {
    filter: { status: { _eq: 'published' } },
    sort: ['-data_publicacao'],
    limit: 1,
    fields: ['id', 'titulo', 'resumo', 'data_publicacao', 'imagem_destaque', 'autor', 'categoria'],
  })),
  []
);
const featured = allForFeatured[0] || null;
const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || 'http://localhost:8055';
const featuredImg = featured?.imagem_destaque ? `${directusUrl}/assets/${featured.imagem_destaque}` : null;

const categorias: { value: string; label: string }[] = [
  { value: 'todas', label: 'Todas' },
  { value: 'editais', label: 'Editais' },
  { value: 'musica', label: 'Música' },
  { value: 'patrimonio', label: 'Patrimônio' },
  { value: 'artes_visuais', label: 'Artes Visuais' },
  { value: 'institucional', label: 'Institucional' },
  { value: 'educacao', label: 'Educação' },
  { value: 'eventos', label: 'Eventos' },
];

const featuredDate = featured
  ? new Date(featured.data_publicacao).toLocaleDateString('pt-BR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const categoriaLabels: Record<string, string> = {
  destaque: 'Destaque',
  editais: 'Editais',
  musica: 'Música',
  patrimonio: 'Patrimônio',
  artes_visuais: 'Artes Visuais',
  institucional: 'Institucional',
  educacao: 'Educação',
  eventos: 'Eventos',
};
---

<Layout title="Notícias" description="Acompanhe as novidades, editais e coberturas dos principais eventos culturais do Estado do Acre">
  <div class="max-w-container-max-width mx-auto px-gutter py-8">

    <!-- Hero -->
    <section class="relative mb-14 overflow-hidden rounded-2xl bg-gradient-to-br from-primary via-primary-container to-primary/80 min-h-[200px] md:min-h-[240px] flex items-center">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <svg class="absolute -top-10 -right-10 w-64 h-64 text-on-primary/5" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="1" />
          <circle cx="100" cy="100" r="55" stroke="currentColor" stroke-width="1" />
          <circle cx="100" cy="100" r="30" stroke="currentColor" stroke-width="1" />
        </svg>
        <svg class="absolute -bottom-8 -left-8 w-48 h-48 text-on-primary/[0.04]" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="10" y="10" width="180" height="180" rx="20" stroke="currentColor" stroke-width="1" />
          <rect x="35" y="35" width="130" height="130" rx="10" stroke="currentColor" stroke-width="1" />
        </svg>
        <svg class="absolute top-1/2 right-1/4 -translate-y-1/2 w-32 h-32 text-on-primary/[0.03]" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M50 10L90 50L50 90L10 50L50 10Z" stroke="currentColor" stroke-width="1" />
        </svg>
      </div>
      <div class="relative z-10 w-full px-8 md:px-12 py-8 md:py-10">
        <nav class="flex items-center gap-2 text-on-primary/70 font-sans text-label-md mb-4">
          <a href="/" class="hover:text-on-primary transition-colors">Início</a>
          <span class="material-symbols-outlined text-[16px]">chevron_right</span>
          <span class="text-on-primary/90">Notícias</span>
        </nav>
        <h1 class="font-display text-display-lg text-on-primary mb-3">Últimas Notícias</h1>
        <p class="font-sans text-body-lg text-on-primary opacity-90">
          Acompanhe as novidades, editais e coberturas dos principais eventos culturais do Estado.
        </p>
      </div>
    </section>

    {featured && activeCategoria === 'todas' && currentPage === 1 && (
      <section class="max-w-container-max-width mx-auto px-gutter mb-section-gap">
        <a href={`/noticias/${featured.id}`} class="group block relative w-full aspect-[4/3] md:aspect-[21/9] rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 bg-surface-container-high">
          {featuredImg ? (
            <img src={featuredImg} alt={featured.titulo} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <span class="material-symbols-outlined text-5xl text-outline">image</span>
            </div>
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent flex flex-col justify-end p-8 md:p-12">
            <div class="flex gap-3 mb-4">
              <span class="px-4 py-1.5 rounded-full bg-primary text-on-primary font-label-md text-label-md uppercase tracking-wide">Destaque</span>
              {featured.categoria && (
                <span class="px-4 py-1.5 rounded-full bg-surface-container-lowest/20 backdrop-blur-sm text-on-primary font-label-md text-label-md uppercase tracking-wide">
                  {categoriaLabels[featured.categoria] || featured.categoria}
                </span>
              )}
            </div>
            <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-primary mb-4 max-w-4xl group-hover:text-primary-fixed transition-colors">
              {featured.titulo}
            </h2>
            {featured.resumo && (
              <p class="hidden md:block font-body-lg text-body-lg text-surface-container-high max-w-3xl mb-6">{featured.resumo}</p>
            )}
            <div class="flex items-center text-primary-fixed font-label-md text-label-md group-hover:translate-x-2 transition-transform">
              Leia a matéria completa <span class="material-symbols-outlined ml-2 text-[20px]">arrow_forward</span>
            </div>
          </div>
        </a>
      </section>
    )}

    <section class="max-w-container-max-width mx-auto px-gutter mb-12">
      <div class="flex flex-wrap items-center gap-3">
        {categorias.map((cat) => {
          const isActive = cat.value === activeCategoria;
          const params = new URLSearchParams();
          if (cat.value !== 'todas') params.set('categoria', cat.value);
          params.delete('page');
          const href = cat.value === 'todas' ? '/noticias' : `/noticias?${params.toString()}`;
          return isActive ? (
            <span class="px-5 py-2.5 rounded-full bg-primary text-on-primary font-label-md text-label-md transition-all whitespace-nowrap">{cat.label}</span>
          ) : (
            <a href={href} class="px-5 py-2.5 rounded-full bg-primary/5 text-primary border border-primary/10 hover:bg-primary/10 hover:border-primary/20 font-label-md text-label-md transition-all whitespace-nowrap">{cat.label}</a>
          );
        })}
      </div>
    </section>

    {noticias.length > 0 ? (
      <section class="max-w-container-max-width mx-auto px-gutter mb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
          {noticias.map((noticia) => <CardNoticia noticia={noticia} />)}
        </div>
      </section>
    ) : (
      <section class="max-w-container-max-width mx-auto px-gutter mb-16">
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-outline">newspaper</span>
          <p class="font-sans text-body-md text-on-surface-variant mt-2">Nenhuma notícia encontrada nesta categoria.</p>
        </div>
      </section>
    )}

    <section class="max-w-container-max-width mx-auto px-gutter">
      <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={activeCategoria !== 'todas' ? `/noticias?categoria=${activeCategoria}` : '/noticias'} />
    </section>
  </div>
</Layout>
