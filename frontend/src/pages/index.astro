---
import Layout from '../layouts/Layout.astro';
import { obterUltimasNoticias, obterServicos, obterEditaisAbertos, obterTodasNoticias, obterTodosEventos, obterTodosEditais, obterCategoriasEditais, obterResultadosRecentes } from '../lib/directus';

const servicos = await obterServicos();
const editaisAbertos = await obterEditaisAbertos();

const noticias = await obterUltimasNoticias(3);
const featuredNews = noticias.length > 0 ? noticias[0] : null;
const sideNews = noticias.filter((_, i) => i > 0).slice(0, 2);
const totalNoticias = (await obterTodasNoticias()).length;
const totalEventos = (await obterTodosEventos()).length;
const totalEditais = (await obterTodosEditais()).length;

const categoriasFomento = await obterCategoriasEditais();
const resultadosRecentes = await obterResultadosRecentes(4);

const programasFomento = categoriasFomento.length > 0 ? categoriasFomento : [
  { id: null, nome: 'Lei Paulo Gustavo', slug: 'lei-paulo-gustavo' },
  { id: null, nome: 'PNAB', slug: 'pnab' },
  { id: null, nome: 'Fundo Estadual de Cultura', slug: 'fundo-estadual' },
  { id: null, nome: 'Chamamento Público', slug: '' },
];

const programasIcons: Record<string, string> = {
  'lei-paulo-gustavo': 'palette',
  'pnab': 'diversity_3',
  'fundo-estadual': 'account_balance',
  '': 'campaign',
};
---

<Layout title="Início" description="Portal oficial da Fundação de Cultura Elias Mansour - FEM, Governo do Estado do Acre">

  <!-- ═══════════════════════════════════════════════════════════
       HERO — NOTÍCIA EM DESTAQUE
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative h-[600px] md:h-[819px] min-h-[600px] w-full flex items-end pb-section-gap px-margin-mobile md:px-gutter overflow-hidden bg-[#191d17]">
    {featuredNews?.imagem_destaque ? (
      <img src={`/api/file/${featuredNews.imagem_destaque}`} alt="" class="absolute top-0 left-1/2 -translate-x-1/2 h-full w-auto max-w-none object-cover" />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-container to-surface-container-high"></div>
    )}
    <!-- Gradientes horizontais para misturar as laterais com o fundo escuro -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#191d17] via-[#191d17]/40 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-l from-[#191d17] via-[#191d17]/40 to-transparent"></div>
    <!-- Gradiente vertical para contraste do texto -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#191d17] via-[#191d17]/60 to-transparent"></div>
    <div class="absolute inset-0 hero-overlay"></div>
    <div class="relative z-10 max-w-container-max-width mx-auto w-full flex flex-col items-start gap-unit">
      {featuredNews ? (
        <>
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface/15 backdrop-blur-sm border border-surface/25 text-on-primary font-sans text-label-md mb-2">
            <span class="material-symbols-outlined text-[16px]" aria-hidden="true">newspaper</span>
            Notícia em Destaque
          </span>
          <p class="font-sans text-body-sm text-surface-container/80">
            {new Date(featuredNews.data_publicacao).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </p>
          <h1 class="font-display text-display-sm md:text-display-lg text-on-primary max-w-3xl leading-tight">{featuredNews.titulo}</h1>
          {featuredNews.resumo && (
            <p class="font-sans text-body-lg text-surface-container max-w-2xl mt-4 mb-6">{featuredNews.resumo}</p>
          )}
          <a href={`/noticias/${featuredNews.id}`}
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-container text-on-primary font-sans text-label-md px-8 py-4 rounded-xl transition-all duration-300 hover:scale-[1.02] hover:shadow-lg">
            Ler Matéria
            <span class="material-symbols-outlined text-[20px]" aria-hidden="true">arrow_forward</span>
          </a>
        </>
      ) : (
        <>
          <span class="inline-block px-4 py-1.5 rounded-full bg-surface/15 backdrop-blur-sm border border-surface/25 text-on-primary font-sans text-label-md mb-2">Fundação Elias Mansour</span>
          <h1 class="font-display text-display-sm md:text-display-lg text-on-primary max-w-3xl leading-tight">Cultura que<br/>transforma o Acre</h1>
          <p class="font-sans text-body-lg text-surface-container max-w-2xl mt-4 mb-6">
            Fomento para projetos artísticos, preservação do patrimônio e desenvolvimento da economia criativa.
          </p>
          <a href="/editais"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-container text-on-primary font-sans text-label-md px-8 py-4 rounded-xl transition-all duration-300 hover:scale-[1.02] hover:shadow-lg">
            Explorar
            <span class="material-symbols-outlined text-[20px]" aria-hidden="true">arrow_forward</span>
          </a>
        </>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       PROGRAMAS DE FOMENTO
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 px-margin-mobile md:px-gutter bg-surface-container-lowest border-b border-outline-variant/20">
    <div class="max-w-container-max-width mx-auto">
      <div class="text-center mb-10">
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg text-on-surface">Programas de Fomento</h2>
        <p class="font-sans text-body-md text-on-surface-variant mt-2">Conheça as linhas de incentivo à cultura acreana</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {programasFomento.map((prog) => {
          const isChamamento = !prog.slug;
          const progSlug = isChamamento ? '' : prog.slug;
          const href = isChamamento ? '/editais' : `/editais?categoria=${progSlug}`;
          const icon = programasIcons[progSlug] || 'description';
          return (
            <a href={href}
              class="group relative bg-surface rounded-2xl border border-outline-variant/20 p-6 text-center hover:border-primary/30 hover:shadow-sm transition-all duration-200">
              <div class="w-12 h-12 rounded-xl bg-primary-container/20 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-200">
                <span class="material-symbols-outlined text-primary text-2xl" aria-hidden="true">{icon}</span>
              </div>
              <h3 class="font-label-md text-label-md text-on-surface group-hover:text-primary transition-colors">{prog.nome}</h3>
              <p class="font-body-sm text-body-sm text-on-surface-variant mt-1 group-hover:text-primary transition-colors">Acessar</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       NÚMEROS DA CULTURA
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-12 px-margin-mobile md:px-gutter border-b border-outline-variant/20">
    <div class="max-w-container-max-width mx-auto">
      <div class="flex flex-wrap justify-center gap-x-12 gap-y-6">
        <div class="text-center">
          <p class="font-display text-display-sm text-primary font-bold">{totalEditais}</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">editais publicados</p>
        </div>
        <div class="text-center">
          <p class="font-display text-display-sm text-primary font-bold">{totalEventos}</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">eventos realizados</p>
        </div>
        <div class="text-center">
          <p class="font-display text-display-sm text-primary font-bold">{totalNoticias}</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">notícias publicadas</p>
        </div>
        <div class="text-center">
          <p class="font-display text-display-sm text-primary font-bold">{editaisAbertos.length}</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">editais abertos agora</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       EDITAIS ABERTOS (mini-cards)
  ═══════════════════════════════════════════════════════════ -->
  {editaisAbertos.length > 0 && (
    <section data-reveal class="py-16 px-margin-mobile md:px-gutter bg-surface-container-lowest border-b border-outline-variant/20">
      <div class="max-w-container-max-width mx-auto">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="font-display text-headline-lg-mobile md:text-headline-lg text-on-surface">Editais Abertos</h2>
            <p class="font-sans text-body-md text-on-surface-variant mt-1">Oportunidades com inscrições abertas</p>
          </div>
          <a href="/editais" class="text-primary font-label-md text-label-md hover:underline hidden md:block">
            Ver todos <span class="material-symbols-outlined text-[16px] align-text-bottom" aria-hidden="true">arrow_forward</span>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {editaisAbertos.slice(0, 3).map((edital) => {
            const catObj = typeof edital.categoria === 'object' && edital.categoria ? edital.categoria as { nome: string } : null;
            const dataEncerra = new Date(edital.data_encerramento).toLocaleDateString('pt-BR');
            const diasRestantes = Math.ceil((new Date(edital.data_encerramento).getTime() - Date.now()) / (1000 * 60 * 60 * 24));
            return (
              <a href={`/editais/${edital.id}`}
                class="group bg-surface rounded-2xl border border-outline-variant/20 p-5 hover:border-primary/30 hover:shadow-sm transition-all duration-200">
                <div class="flex items-center gap-2 mb-3">
                  <span class="w-2 h-2 rounded-full bg-primary"></span>
                  <span class="font-label-md text-label-md text-primary">Aberto</span>
                  {catObj && <span class="font-body-sm text-body-sm text-on-surface-variant">· {catObj.nome}</span>}
                </div>
                <p class="font-body-sm text-body-sm text-on-surface-variant mb-1">Edital nº {edital.numero}</p>
                <h3 class="font-label-md text-label-md text-on-surface group-hover:text-primary transition-colors line-clamp-2 mb-3">{edital.titulo}</h3>
                <div class="flex items-center justify-between">
                  <span class="font-body-sm text-body-sm text-on-surface-variant">Encerra {dataEncerra}</span>
                  {diasRestantes <= 7 && (
                    <span class="font-label-md text-label-md text-error flex items-center gap-1">
                      <span class="material-symbols-outlined text-[14px]" aria-hidden="true">schedule</span>
                      {diasRestantes}d
                    </span>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       RESULTADOS RECENTES
  ═══════════════════════════════════════════════════════════ -->
  {resultadosRecentes.length > 0 && (
    <section data-reveal class="py-16 px-margin-mobile md:px-gutter border-b border-outline-variant/20">
      <div class="max-w-container-max-width mx-auto">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="font-display text-headline-lg-mobile md:text-headline-lg text-on-surface">Resultados Recentes</h2>
            <p class="font-sans text-body-md text-on-surface-variant mt-1">Confira os resultados dos últimos editais</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {resultadosRecentes.map((res) => {
            const editalRel = res.edital_relacionado && typeof res.edital_relacionado === 'object' ? res.edital_relacionado as { id: number; titulo: string; numero: string } : null;
            return (
              <a href={res.arquivo ? `/api/file/${res.arquivo}` : '#'} target={res.arquivo ? '_blank' : undefined} rel={res.arquivo ? 'noopener noreferrer' : undefined}
                class="group bg-surface-container-lowest rounded-2xl border border-outline-variant/20 p-5 hover:border-primary/30 hover:shadow-sm transition-all duration-200 flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-surface-container flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined text-on-surface-variant" aria-hidden="true">fact_check</span>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-label-md text-label-md text-on-surface group-hover:text-primary transition-colors truncate">{res.titulo}</h3>
                  {editalRel && <p class="font-body-sm text-body-sm text-on-surface-variant truncate">{editalRel.titulo}</p>}
                  <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">{new Date(res.data_publicacao).toLocaleDateString('pt-BR')}</p>
                </div>
                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors" aria-hidden="true">arrow_forward</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       NOTÍCIAS
  ═══════════════════════════════════════════════════════════ -->
  {noticias.length > 0 && (
    <section data-reveal class="py-16 px-margin-mobile md:px-gutter bg-surface-container-lowest border-b border-outline-variant/20">
      <div class="max-w-container-max-width mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="w-1 h-8 bg-primary rounded-full"></span>
              <h2 class="font-display text-headline-lg-mobile md:text-headline-lg text-on-background">Notícias Culturais</h2>
            </div>
            <p class="font-sans text-body-md text-on-surface-variant mt-2 ml-4">As últimas movimentações do cenário acreano.</p>
          </div>
          <a href="/noticias" class="text-primary font-sans text-label-md hover:underline items-center gap-1 group hidden md:flex">
            Ver todas as notícias
            <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
          {featuredNews && (
            <article class="md:col-span-7 group cursor-pointer">
              <a href={`/noticias/${featuredNews.id}`}>
                <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden mb-6 shadow-md group-hover:shadow-xl transition-shadow duration-300 bg-surface-container-high img-shimmer">
                  {featuredNews.imagem_destaque ? (
                    <img src={`/api/file/${featuredNews.imagem_destaque}`} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" onLoad="this.parentElement.classList.remove('img-shimmer')" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <span class="material-symbols-outlined text-5xl text-outline" aria-hidden="true">image</span>
                    </div>
                  )}
                </div>
                <time class="font-sans text-[14px] text-on-surface-variant mb-2 block">
                  {new Date(featuredNews.data_publicacao).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' }).replace('.', '')}
                </time>
                <h3 class="font-display text-headline-md text-on-background group-hover:text-primary transition-colors mb-3">{featuredNews.titulo}</h3>
                {featuredNews.resumo && (
                  <p class="font-sans text-body-md text-on-surface-variant line-clamp-2">{featuredNews.resumo}</p>
                )}
              </a>
            </article>
          )}

          {sideNews.length > 0 && (
            <div class="md:col-span-5 flex flex-col gap-8">
              {sideNews.map((noticia) => {
                const sideDate = new Date(noticia.data_publicacao).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' }).replace('.', '');
                return (
                  <article class="group cursor-pointer flex gap-4 items-center md:items-start border-b border-outline-variant/20 pb-6 last:border-b-0 last:pb-0">
                    <a href={`/noticias/${noticia.id}`} class="flex gap-4 w-full">
                      <div class="relative w-28 md:w-36 aspect-[4/3] flex-shrink-0 rounded-xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow bg-surface-container-high img-shimmer">
                        {noticia.imagem_destaque ? (
                          <img src={`/api/file/${noticia.imagem_destaque}`} alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" onLoad="this.parentElement.classList.remove('img-shimmer')" />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center">
                            <span class="material-symbols-outlined text-2xl text-outline" aria-hidden="true">image</span>
                          </div>
                        )}
                      </div>
                      <div class="flex flex-col justify-center h-full min-h-0">
                        <h3 class="font-display text-[18px] font-semibold text-on-background leading-snug group-hover:text-primary transition-colors mb-2 line-clamp-3">{noticia.titulo}</h3>
                        <time class="font-sans text-[13px] text-on-surface-variant flex items-center gap-1">
                          <span class="material-symbols-outlined text-[14px]" aria-hidden="true">schedule</span>
                          {sideDate}
                        </time>
                      </div>
                    </a>
                  </article>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       SERVIÇOS
  ═══════════════════════════════════════════════════════════ -->
  <section data-reveal class="py-16 px-margin-mobile md:px-gutter max-w-container-max-width mx-auto">
    <div class="flex justify-between items-end mb-12">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <span class="w-1 h-8 bg-primary rounded-full"></span>
          <h2 class="font-display text-headline-lg-mobile md:text-headline-lg text-on-background">Serviços ao Artista</h2>
        </div>
        <p class="font-sans text-body-md text-on-surface-variant mt-2 ml-4">Acesse os serviços essenciais para fazedores de cultura.</p>
      </div>
      <a href="/servicos" class="text-primary font-sans text-label-md hover:underline items-center gap-1 group hidden md:flex">
        Ver todos
        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[240px]">
      {servicos.length > 0 ? (
        servicos.filter(s => s.titulo !== 'Transparência').slice(0, 5).map((servico, i) => {
          const isLarge = i === 0;
          const colors = [
            { bg: 'bg-surface-container-low', icon: 'how_to_reg', iconBg: 'bg-primary-container/20', iconColor: 'text-primary' },
            { bg: 'bg-surface-container-low', icon: 'map', iconBg: 'bg-secondary/10', iconColor: 'text-secondary' },
            { bg: 'bg-surface-container-low', icon: 'museum', iconBg: 'bg-primary/10', iconColor: 'text-primary' },
            { bg: 'bg-primary', icon: 'event', iconBg: 'bg-on-primary/10', iconColor: 'text-on-primary' },
            { bg: 'bg-surface-container-low', icon: 'calendar_month', iconBg: 'bg-tertiary-container/10', iconColor: 'text-tertiary-container' },
          ];
          const c = colors[i % colors.length];
          const isPrimary = c.bg === 'bg-primary';
          return (
            <a
              href={servico.url || '/servicos'}
              target={servico.url ? '_blank' : undefined}
              rel={servico.url ? 'noopener noreferrer' : undefined}
              class={`group relative rounded-2xl overflow-hidden soft-elevation ${isLarge ? 'md:col-span-2 md:row-span-2' : ''} ${c.bg} ${isPrimary ? '' : 'border border-outline-variant/30 hover:bg-surface-container transition-colors'} block`}
            >
              {isLarge && (
                <div class={`absolute inset-0 ${servico.url ? '' : 'bg-gradient-to-br from-primary/5 to-primary/10'}`}></div>
              )}
              <div class={`relative ${isLarge ? 'h-full flex flex-col justify-end p-8' : 'flex flex-col p-6 h-full'}`}>
                {isLarge ? (
                  <>
                    <div class={`${c.iconBg} backdrop-blur-md w-12 h-12 rounded-full flex items-center justify-center mb-4`}>
                      <span class={`material-symbols-outlined ${c.iconColor}`} aria-hidden="true">{c.icon}</span>
                    </div>
                    <h3 class="font-display text-headline-md text-on-surface mb-2">{servico.titulo}</h3>
                    {servico.descricao && <p class="font-sans text-body-md text-on-surface-variant max-w-md">{servico.descricao}</p>}
                  </>
                ) : (
                  <>
                    <div class={`w-10 h-10 rounded-full ${c.iconBg} flex items-center justify-center mb-auto ${c.iconColor}`}>
                      <span class="material-symbols-outlined" aria-hidden="true">{c.icon}</span>
                    </div>
                    <div>
                      <h3 class={`font-display text-[22px] ${isPrimary ? 'text-on-primary' : 'text-on-background'} mb-1`}>{servico.titulo}</h3>
                      {servico.descricao && <p class={`font-sans text-body-md ${isPrimary ? 'text-primary-fixed' : 'text-on-surface-variant'} text-sm`}>{servico.descricao}</p>}
                    </div>
                    <div class={`absolute top-6 right-6 opacity-0 group-hover:opacity-100 transition-opacity ${isPrimary ? 'text-on-primary' : 'text-primary'}`}>
                      <span class="material-symbols-outlined" aria-hidden="true">arrow_outward</span>
                    </div>
                  </>
                )}
              </div>
            </a>
          );
        })
      ) : (
        <div class="md:col-span-3 text-center py-16 text-on-surface-variant">
          <p class="font-sans text-body-lg">Nenhum serviço disponível no momento.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       REDES SOCIAIS
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 px-margin-mobile md:px-gutter border-t border-outline-variant/20">
    <div class="max-w-container-max-width mx-auto flex flex-col items-center gap-6">
      <p class="font-body-md text-body-md text-on-surface-variant">Acompanhe a FEM nas redes sociais</p>
      <div class="flex items-center gap-2">
        <a href="https://instagram.com/fem.ac" target="_blank" rel="noopener noreferrer"
          aria-label="Instagram da FEM (abre em nova aba)"
          class="w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary hover:bg-primary-container/20 transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
