      <rect x="34" y="43" width="30" height="3" rx="1.5" fill="#E65100" opacity="0.2"/>
      <path d="M78 36l-8-8M78 36l-8 8" stroke="#E65100" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    </svg>`,
