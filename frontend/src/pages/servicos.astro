  {
    nome: 'Ponto Web',
    descricao: 'Sistema de ponto eletrônico',
    url: 'https://pontoweb.ac.gov.br/',
    cor: '#6A1B9A',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#F3E5F5"/>
      <circle cx="60" cy="36" r="20" fill="#6A1B9A" opacity="0.1"/>
      <circle cx="60" cy="36" r="14" fill="none" stroke="#6A1B9A" stroke-width="2.5"/>
      <circle cx="60" cy="36" r="6" fill="#6A1B9A" opacity="0.2"/>
      <path d="M60 28v10l6 4" stroke="#6A1B9A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="60" cy="36" r="2" fill="#6A1B9A"/>
      <path d="M44 28l-3 3M76 28l-3 3" stroke="#6A1B9A" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
    </svg>`,
