---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const sistemas = [
  {
    nome: 'SEI',
    descricao: 'Sistema Eletrônico de Informações',
    url: 'https://sei.ac.gov.br/',
    externo: true,
    cor: '#1565C0',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#E3F2FD"/>
      <rect x="35" y="18" width="50" height="36" rx="6" fill="#1565C0" opacity="0.12"/>
      <path d="M42 30h36M42 38h28M42 46h22" stroke="#1565C0" stroke-width="3" stroke-linecap="round"/>
    </svg>`,
  },
  {
    nome: 'Mapa Cultural',
    descricao: 'Plataforma de mapeamento cultural do Acre',
    url: 'https://mapadacultura.ac.gov.br/',
    externo: true,
    cor: '#00897B',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#E0F2F1"/>
      <circle cx="60" cy="34" r="18" fill="#00897B" opacity="0.15"/>
      <path d="M60 20v28M46 34h28" stroke="#00897B" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="60" cy="34" r="6" fill="none" stroke="#00897B" stroke-width="2.5"/>
    </svg>`,
  },
  {
    nome: 'Diário Oficial',
    descricao: 'Publicações oficiais do Estado',
    url: 'https://diario.ac.gov.br/',
    externo: true,
    cor: '#F57F17',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#FFF8E1"/>
      <rect x="30" y="18" width="60" height="40" rx="4" fill="#F57F17" opacity="0.1"/>
      <rect x="36" y="24" width="48" height="3" rx="1.5" fill="#F57F17"/>
      <rect x="36" y="32" width="40" height="3" rx="1.5" fill="#F57F17" opacity="0.6"/>
      <rect x="36" y="40" width="44" height="3" rx="1.5" fill="#F57F17" opacity="0.4"/>
    </svg>`,
  },
  {
    nome: 'GRP',
    descricao: 'Gestão de Recursos Patrimoniais',
    url: 'http://grp.ac.gov.br/asi/',
    externo: false,
    cor: '#2E7D32',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#E8F5E9"/>
      <circle cx="60" cy="34" r="18" fill="#2E7D32" opacity="0.12"/>
      <path d="M52 28l-4 12h24l-4-12H52z" fill="none" stroke="#2E7D32" stroke-width="2.5" stroke-linejoin="round"/>
      <rect x="56" y="32" width="8" height="8" rx="2" fill="#2E7D32"/>
    </svg>`,
  },
  {
    nome: 'Ponto Web',
    descricao: 'Sistema de ponto eletrônico',
    url: 'https://pontoweb.ac.gov.br/',
    externo: true,
    cor: '#7B1FA2',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#F3E5F5"/>
      <circle cx="60" cy="34" r="18" fill="#7B1FA2" opacity="0.12"/>
      <circle cx="60" cy="34" r="8" fill="none" stroke="#7B1FA2" stroke-width="2.5"/>
      <path d="M60 30v6h4" stroke="#7B1FA2" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    nome: 'Chamados FEM',
    descricao: 'Abertura e acompanhamento de chamados',
    url: 'http://10.24.18.20/',
    externo: false,
    cor: '#C62828',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#FFEBEE"/>
      <rect x="44" y="22" width="32" height="32" rx="8" fill="#C62828" opacity="0.12"/>
      <path d="M52 32h16M52 40h12" stroke="#C62828" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M60 28v4" stroke="#C62828" stroke-width="2.5"/>
    </svg>`,
  },
  {
    nome: 'Biblivre',
    descricao: 'Sistema de biblioteca digital',
    url: 'http://10.24.18.25:3000/Biblivre6/',
    externo: false,
    cor: '#283593',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#E8EAF6"/>
      <path d="M40 22v32l20-8 20 8V22l-20 8-20-8z" fill="#283593" opacity="0.12"/>
      <path d="M40 22v32l20-8 20 8V22l-20 8-20-8z" fill="none" stroke="#283593" stroke-width="2.5" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    nome: 'GVC',
    descricao: 'Controle de acesso e visitantes',
    url: 'http://10.24.18.50:3000/gerenciamento',
    externo: false,
    cor: '#00838F',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#E0F7FA"/>
      <circle cx="48" cy="30" r="6" fill="#00838F" opacity="0.3"/>
      <circle cx="72" cy="30" r="6" fill="#00838F" opacity="0.3"/>
      <path d="M42 42c0-5 6-8 18-8s18 3 18 8" fill="none" stroke="#00838F" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    nome: 'Agendamento de Espaços',
    descricao: 'Reserve teatros, museus e salas',
    url: 'http://10.24.18.50:3000/agendamento',
    externo: false,
    cor: '#AD1457',
    logoSvg: `<svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="72" rx="10" fill="#FCE4EC"/>
      <rect x="40" y="22" width="40" height="30" rx="4" fill="#AD1457" opacity="0.1"/>
      <path d="M40 30h40" stroke="#AD1457" stroke-width="2.5"/>
      <rect x="46" y="20" width="4" height="6" rx="1" fill="#AD1457"/>
      <rect x="70" y="20" width="4" height="6" rx="1" fill="#AD1457"/>
      <text x="60" y="44" text-anchor="middle" font-family="system-ui" font-weight="600" font-size="11" fill="#AD1457">17</text>
    </svg>`,
  },
];
---

<Layout
  title="Serviços e Sistemas"
  description="Sistemas, ferramentas e serviços da Fundação de Cultura Elias Mansour"
>
  <div class="max-w-container-max-width mx-auto px-gutter py-8">
    <Breadcrumbs items={[{ label: 'Serviços' }]} />

    <!-- Hero da página -->
    <section class="relative mb-14 overflow-hidden rounded-2xl bg-gradient-to-br from-primary via-primary-container to-primary/80 p-10 md:p-14">
      <div class="relative z-10">
        <h1 class="font-display text-display-lg text-on-primary mb-3">Serviços e Sistemas</h1>
        <p class="font-sans text-body-lg text-on-primary max-w-2xl opacity-90">
          Acesse os sistemas corporativos e ferramentas de gestão da Fundação de Cultura Elias Mansour.
        </p>
      </div>
    </section>

    <!-- Grid de Sistemas -->
    <section class="mb-16">
      <h2 class="font-headline-md text-headline-md text-on-surface mb-8 flex items-center gap-3">
        <span class="material-symbols-outlined text-3xl text-primary">apps</span>
        Sistemas e Ferramentas
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {sistemas.map((s) => (
          <a
            href={s.url}
            target={s.externo ? '_blank' : '_self'}
            rel={s.externo ? 'noopener noreferrer' : undefined}
            class="group bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            style={`--card-cor: ${s.cor}`}
            onclick={s.externo ? undefined : `if(!confirm('Você está acessando um sistema interno da FEM. Certifique-se de estar na rede do governo.'))event.preventDefault()`}
          >
            <!-- Topo: Logo SVG -->
            <div class="flex items-center justify-center p-4 bg-surface-container-low" set:html={s.logoSvg} />

            <!-- Corpo: Nome + Descrição + CTA -->
            <div class="p-5 pt-4">
              <h3 class="font-display text-headline-md text-on-surface group-hover:text-[var(--card-cor)] transition-colors">
                {s.nome}
              </h3>
              <p class="font-sans text-body-md text-on-surface-variant mt-1 line-clamp-2 leading-relaxed">
                {s.descricao}
              </p>

              <div class="mt-5 flex items-center justify-between">
                <span
                  class={`px-3 py-1 rounded-full font-label-md text-xs ${
                    s.externo
                      ? 'bg-primary-container/20 text-on-primary-container'
                      : 'bg-secondary-container/30 text-on-secondary-container'
                  }`}
                >
                  {s.externo ? 'Externo' : 'Interno'}
                </span>
                <span
                  class="inline-flex items-center gap-1 text-label-md font-label-md transition-all duration-300"
                  style="color: var(--card-cor)"
                >
                  Acessar
                  <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Documentações e Portarias -->
    <section class="mb-16">
      <h2 class="font-headline-md text-headline-md text-on-surface mb-8 flex items-center gap-3">
        <span class="material-symbols-outlined text-3xl" style="color:#1565C0">description</span>
        Documentações e Portarias
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a
          href="https://drive.google.com/file/d/1SwwgZcb4UmDh0cYNtIdw-K404mFwuzP2/view"
          target="_blank"
          rel="noopener noreferrer"
          class="group bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div class="flex items-center gap-4 p-5" style="background: #E3F2FD">
            <div class="shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-white/60">
              <span class="material-symbols-outlined" style="color:#1565C0">description</span>
            </div>
            <div>
              <span class="text-sm font-medium" style="color:#1565C0">Documento Oficial</span>
              <span class="block text-xs text-on-surface-variant mt-0.5">2023</span>
            </div>
          </div>
          <div class="p-5 pt-4">
            <h3 class="font-display text-headline-md text-on-surface group-hover:text-secondary transition-colors">
              Portaria nº 169/2023
            </h3>
            <p class="font-sans text-body-md text-on-surface-variant mt-1 leading-relaxed">
              Dispõe sobre o uso e a gestão dos espaços públicos de cultura geridos pela Fundação de Cultura Elias Mansour – FEM.
            </p>
            <div class="mt-4 flex items-center gap-1.5 text-label-md font-label-md" style="color:#1565C0">
              <span>Abrir documento</span>
              <span class="material-symbols-outlined text-[18px]">open_in_new</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Formulários -->
    <section class="mb-16">
      <h2 class="font-headline-md text-headline-md text-on-surface mb-8 flex items-center gap-3">
        <span class="material-symbols-outlined text-3xl" style="color:#6B1D3D">edit_note</span>
        Formulários
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSczzp6ih2L5sAoH3t3b_BELWMHRc_GOXy0bCdbXZlAAgs4TtQ/viewform"
          target="_blank"
          rel="noopener noreferrer"
          class="group bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div class="flex items-center gap-4 p-5" style="background: #FCE4EC">
            <div class="shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-white/60">
              <span class="material-symbols-outlined" style="color:#6B1D3D">edit_note</span>
            </div>
            <div>
              <span class="text-sm font-medium" style="color:#6B1D3D">Formulário</span>
            </div>
          </div>
          <div class="p-5 pt-4 flex items-center justify-between">
            <div>
              <h3 class="font-display text-headline-md text-on-surface group-hover:text-tertiary transition-colors">
                Solicitação de Utilização de Espaço
              </h3>
              <p class="font-sans text-body-md text-on-surface-variant mt-1">
                Formulário para reserva de teatros, museus e espaços culturais
              </p>
            </div>
            <span class="shrink-0 px-5 py-2.5 rounded-full bg-tertiary/10 text-tertiary font-label-md text-label-md group-hover:bg-tertiary group-hover:text-on-primary transition-all whitespace-nowrap ml-4">
              Preencher
            </span>
          </div>
        </a>
      </div>
    </section>
  </div>
</Layout>
