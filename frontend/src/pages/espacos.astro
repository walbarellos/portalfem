---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { espacosEstaticos } from '../lib/espacos-data';
import type { EspacoCultural } from '../schemas/directus';

const espacos = espacosEstaticos as EspacoCultural[];

const categorias: { value: string; label: string }[] = [
  { value: 'todas', label: 'Todos' },
  { value: 'museu', label: 'Museus' },
  { value: 'teatro', label: 'Teatros' },
  { value: 'biblioteca', label: 'Bibliotecas' },
  { value: 'espaco_memoria', label: 'Espaços de Memória' },
  { value: 'centro_cultural', label: 'Centros Culturais' },
];

const categoriaColors: Record<string, string> = {
  museu: 'bg-primary/90',
  teatro: 'bg-secondary/90',
  biblioteca: 'bg-tertiary/90',
  espaco_memoria: 'bg-primary-container/90',
  centro_cultural: 'bg-secondary-container/90',
};

function categoriaLabel(value: string): string {
  const found = categorias.find((c) => c.value === value);
  return found ? found.label : value;
}
---

<Layout title="Espaços Culturais" description="Conheça a rede de museus, teatros, bibliotecas e centros culturais mantidos pelo Estado do Acre">
  <div class="max-w-container-max-width mx-auto px-gutter py-8">

      <PageHero title="Espaços Culturais" description="Conheça os espaços culturais de museus, teatros, bibliotecas e centros culturais mantidos pelo Estado do Acre." breadcrumbLabel="Espaços Culturais" />

    <section class="mb-12 overflow-x-auto pb-4 hide-scrollbar">
      <div id="filter-bar" class="flex gap-3 min-w-max">
        {categorias.map((cat) => {
          return (
            <button data-categoria={cat.value} class="filter-btn px-5 py-2 rounded-full bg-surface-container border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container-high hover:text-primary font-label-md text-label-md transition-all whitespace-nowrap" data-active-class="bg-primary text-on-primary border-primary">
              {cat.label}
            </button>
          );
        })}
      </div>
    </section>

    <section id="espacos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {espacos.map((espaco) => {
        return (
          <a href={`/espacos/${espaco.id}`} data-categoria={espaco.categoria} class="espaco-card group relative rounded-xl overflow-hidden aspect-[4/3] md:aspect-[3/4] lg:aspect-square bg-surface-container-lowest border border-outline-variant/20 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 img-shimmer">
            <div class="absolute inset-0 bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-5xl text-outline">location_city</span>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 flex flex-col justify-end">
              <span class={`${categoriaColors[espaco.categoria] || 'bg-primary/90'} text-on-primary px-3 py-1 rounded-full text-label-md font-label-md w-max mb-3 backdrop-blur-sm`}>
                {categoriaLabel(espaco.categoria)}
              </span>
              <h2 class="font-headline-md text-headline-md text-on-primary mb-2 leading-tight">{espaco.nome}</h2>
              {espaco.endereco && (
                <div class="flex items-center gap-2 text-surface-container-lowest/80 font-body-md text-body-md">
                  <span class="material-symbols-outlined text-[18px]">location_on</span>
                  <span>{espaco.endereco}</span>
                </div>
              )}
            </div>
          </a>
        );
      })}
    </section>

    <div id="espacos-empty" class="text-center py-16" style="display:none">
      <span class="material-symbols-outlined text-4xl text-outline">location_city</span>
      <p class="font-sans text-body-md text-on-surface-variant mt-2">Nenhum espaço cultural encontrado.</p>
    </div>
  </div>
</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBar = document.getElementById('filter-bar');
    const cards = document.querySelectorAll('.espaco-card');
    const buttons = filterBar?.querySelectorAll('.filter-btn');

    function aplicarFiltro(categoria) {
      let temVisivel = false;
      cards.forEach((card) => {
        const cat = card.getAttribute('data-categoria');
        const match = categoria === 'todas' || cat === categoria;
        card.style.display = match ? '' : 'none';
        if (match) temVisivel = true;
      });
      buttons?.forEach((btn) => {
        const isActive = btn.getAttribute('data-categoria') === categoria;
        btn.classList.toggle('bg-primary', isActive);
        btn.classList.toggle('text-on-primary', isActive);
        btn.classList.toggle('border-primary', isActive);
        btn.classList.toggle('bg-surface-container', !isActive);
        btn.classList.toggle('text-on-surface-variant', !isActive);
        btn.classList.toggle('border-outline-variant/30', !isActive);
      });
      const emptyMsg = document.getElementById('espacos-empty');
      if (emptyMsg) emptyMsg.style.display = temVisivel ? 'none' : 'block';
    }

    function getCategoriaFromURL() {
      const params = new URLSearchParams(window.location.search);
      return params.get('categoria') || 'todas';
    }

    // Aplicar filtro inicial baseado na URL
    aplicarFiltro(getCategoriaFromURL());

    // Clique nos botões de filtro
    buttons?.forEach((btn) => {
      btn.addEventListener('click', () => {
        const categoria = btn.getAttribute('data-categoria');
        const url = new URL(window.location);
        if (categoria === 'todas') {
          url.searchParams.delete('categoria');
        } else {
          url.searchParams.set('categoria', categoria);
        }
        window.history.pushState({ categoria }, '', url);
        aplicarFiltro(categoria);
      });
    });

    // Navegação pelo histórico (voltar/avançar)
    window.addEventListener('popstate', () => {
      aplicarFiltro(getCategoriaFromURL());
    });
  });
</script>
