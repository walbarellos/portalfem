---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CardEvento from '../components/CardEvento.astro';
import Pagination from '../components/Pagination.astro';
import { safeRequest, directus, readItems } from '../lib/directus';

const pageSize = 10;
const currentPage = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const offset = (currentPage - 1) * pageSize;
const activeCategoria = Astro.url.searchParams.get('categoria') || 'todas';
const activeView = Astro.url.searchParams.get('view') || 'lista';

const filterBase: Record<string, unknown> = { status: { _eq: 'published' } };
if (activeCategoria !== 'todas') {
  filterBase.categoria = { _eq: activeCategoria };
}

const eventos = await safeRequest(
  directus.request(readItems('eventos', {
    filter: filterBase,
    sort: ['-data_inicio'],
    limit: pageSize,
    offset,
    fields: ['id', 'titulo', 'descricao', 'data_inicio', 'data_fim', 'local', 'imagem_capa', 'categoria', 'destaque', 'horario', 'gratuito', 'link_inscricao'],
  })),
  []
);

const allEventos = await safeRequest(
  directus.request(readItems('eventos', {
    filter: filterBase,
    fields: ['id'],
  })),
  []
);

const total = allEventos.length;
const totalPages = Math.ceil(total / pageSize);

function groupByMonth(items: typeof eventos): Map<string, typeof eventos> {
  const groups = new Map<string, typeof eventos>();
  for (const e of items) {
    const d = new Date(e.data_inicio);
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key)!.push(e);
  }
  return groups;
}

function monthLabel(key: string): string {
  const [year, month] = key.split('-');
  const d = new Date(Number(year), Number(month) - 1);
  return d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
}

function monthKey(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
}

const categorias = [
  { value: 'todas', label: 'Todos' },
  { value: 'musica', label: 'Música' },
  { value: 'teatro', label: 'Teatro' },
  { value: 'artes_visuais', label: 'Artes Visuais' },
  { value: 'literatura', label: 'Literatura' },
];
---

<Layout title="Eventos" description="Agenda cultural da Fundação de Cultura Elias Mansour - Eventos, exposições e apresentações no Acre">
  <div class="max-w-container-max-width mx-auto px-gutter py-8">

    <PageHero title="Agenda Cultural" description="Descubra e participe dos eventos que movimentam a cultura acreana." breadcrumbLabel="Eventos" />

    <!-- Busca -->
    <div class="relative w-full max-w-md mb-6">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant" aria-hidden="true">search</span>
      <input
        id="evento-search"
        aria-label="Filtrar eventos por palavra-chave"
        class="w-full pl-10 pr-4 py-3 rounded-lg border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary bg-surface font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/70 transition-all"
        placeholder="Buscar evento, local ou palavra-chave..."
        type="search"
      />
    </div>

    <!-- Toolbar -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div class="flex flex-wrap items-center gap-3">
        {categorias.map((cat) => {
          const isActive = cat.value === activeCategoria;
          const params = new URLSearchParams();
          if (cat.value !== 'todas') params.set('categoria', cat.value);
          params.delete('page');
          const href = cat.value === 'todas' ? '/eventos' : `/eventos?${params.toString()}`;
          return isActive ? (
            <span class="px-4 py-2 rounded-full bg-primary-container text-on-primary-container font-label-md text-label-md border border-primary/20 cursor-default">{cat.label}</span>
          ) : (
            <a href={href} class="px-4 py-2 rounded-full bg-surface-container text-on-surface-variant font-label-md text-label-md border border-outline-variant/50 hover:border-primary/50 transition-colors">{cat.label}</a>
          );
        })}
      </div>
      <div class="flex bg-surface-container-high rounded-full p-1">
        <a href={activeCategoria === 'todas' ? '?view=lista' : `?categoria=${activeCategoria}&view=lista`} class={`px-6 py-2 rounded-full font-label-md text-label-md transition-all flex items-center gap-2 ${activeView === 'lista' ? 'bg-primary text-on-primary' : 'text-on-surface-variant'}`}>
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">view_list</span>
          Lista
        </a>
        <a href={activeCategoria === 'todas' ? '?view=mes' : `?categoria=${activeCategoria}&view=mes`} class={`px-6 py-2 rounded-full font-label-md text-label-md transition-all flex items-center gap-2 ${activeView === 'mes' ? 'bg-primary text-on-primary' : 'text-on-surface-variant'}`}>
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">calendar_month</span>
          Mês
        </a>
      </div>
    </div>

    <!-- Contador -->
    <p class="font-body-md text-body-md text-on-surface-variant mb-6" id="result-count" aria-live="polite" aria-atomic="true">Mostrando <strong>{total}</strong> {total === 1 ? 'evento' : 'eventos'}</p>

    {eventos.length > 0 ? (
      activeView === 'mes' ? (
        <div class="flex flex-col gap-12" id="eventos-list">
          {Array.from(groupByMonth(eventos).entries()).map(([key, events]) => (
            <section data-group={key}>
              <h2 class="font-headline-md text-headline-md text-primary mb-6 capitalize">{monthLabel(key)}</h2>
              <div class="flex flex-col gap-6">
                {events.map((evento) => <CardEvento evento={evento} />)}
              </div>
            </section>
          ))}
        </div>
      ) : (
        <section>
          <h2 class="sr-only">Lista de Eventos</h2>
          <div class="flex flex-col gap-6" id="eventos-list">
            {eventos.map((evento) => <CardEvento evento={evento} />)}
          </div>
        </section>
      )
    ) : (
      <div class="text-center py-16">
        <span class="material-symbols-outlined text-4xl text-outline" aria-hidden="true">event_busy</span>
        <p class="font-sans text-body-md text-on-surface-variant mt-2">Nenhum evento encontrado.</p>
      </div>
    )}

    <!-- Paginação -->
    <section class="max-w-container-max-width mx-auto px-gutter mt-12">
      <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={activeCategoria !== 'todas' ? `/eventos?categoria=${activeCategoria}` : '/eventos'} />
    </section>
  </div>
</Layout>

<script>
  const input = document.querySelector('input[type="text"]');
  const count = document.getElementById('result-count');
  const list = document.getElementById('eventos-list');

  if (input && count && list) {
    const totalText = count.textContent || '0';
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      const cards = list.querySelectorAll('[data-search]');
      const groups = list.querySelectorAll('[data-group]');
      let visible = 0;

      cards.forEach((card) => {
        const match = !q || card.dataset.search.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      groups.forEach((group) => {
        const hasVisible = Array.from(group.querySelectorAll('[data-search]')).some(
          (c) => (c as HTMLElement).style.display !== 'none'
        );
        (group as HTMLElement).style.display = hasVisible ? '' : 'none';
      });

      count.innerHTML = q
        ? `Mostrando <strong>${visible}</strong> de <strong>${totalText.match(/\d+/)?.[0] || 0}</strong> eventos`
        : `Mostrando <strong>${totalText.match(/\d+/)?.[0] || 0}</strong> eventos`;
    });
  }
</script>
