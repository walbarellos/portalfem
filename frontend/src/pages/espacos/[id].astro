---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { espacosEstaticos } from '../../lib/espacos-data';

export async function getStaticPaths() {
  return espacosEstaticos.map((e) => ({
    params: { id: String(e.id) },
    props: { nome: e.nome, descricao: e.descricao },
  }));
}

const { id } = Astro.params;
const item = espacosEstaticos.find((e) => e.id === Number(id)) ?? null;

if (!item) return Astro.redirect('/404');

const imgSrc = null;
---

<Layout title={item.nome} description={item.descricao?.slice(0, 160)} image={imgSrc || undefined}>
  <div class="max-w-container-max-width mx-auto px-gutter py-8">
    <Breadcrumbs items={[
      { label: 'Espaços Culturais', href: '/espacos' },
      { label: item.nome },
    ]} />

    <article class="max-w-3xl mx-auto">
      {imgSrc && (
        <div class="aspect-video rounded-xl overflow-hidden mb-8 bg-surface-container-high img-shimmer">
          <img src={imgSrc} alt={item.nome} class="w-full h-full object-cover" onLoad="this.parentElement.classList.remove('img-shimmer')" />
        </div>
      )}

      <header class="mb-8">
        <h1 class="font-display text-display-sm md:text-display-lg text-on-surface leading-tight">{item.nome}</h1>
      </header>

      <div class="prose prose-green max-w-none">
        <Fragment set:html={item.descricao} />
      </div>

      <div class="mt-8 space-y-4 bg-surface-container-low rounded-xl p-6">
        {item.endereco && (
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-on-surface-variant" aria-hidden="true">location_on</span>
            <div>
              <span class="font-sans text-label-md text-on-surface">Endereço</span>
              <p class="font-sans text-body-md text-on-surface-variant">{item.endereco}</p>
            </div>
          </div>
        )}
        {item.horario_funcionamento && (
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-on-surface-variant" aria-hidden="true">schedule</span>
            <div>
              <span class="font-sans text-label-md text-on-surface">Horário de Funcionamento</span>
              <p class="font-sans text-body-md text-on-surface-variant">{item.horario_funcionamento}</p>
            </div>
          </div>
        )}
      </div>
    </article>
  </div>
</Layout>
