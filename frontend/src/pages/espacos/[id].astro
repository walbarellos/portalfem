---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { directus, safeRequest, readItems, getEspacosCulturais } from '../../lib/directus';
import type { EspacoCultural } from '../../schemas/directus';

export async function getStaticPaths() {
  const espacos = await getEspacosCulturais();
  return espacos.map((e: EspacoCultural) => ({
    params: { id: String(e.id) },
    props: { espaco: e },
  }));
}

const { id } = Astro.params;
const item = await safeRequest(
  directus.request(readItems('espacos_culturais', {
    filter: { id: { _eq: Number(id) }, status: { _eq: 'published' } },
    limit: 1,
  })),
  []
).then((r) => r?.[0] ?? null);

if (!item) return Astro.redirect('/404');

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || 'http://localhost:8055';
const imgSrc = item.imagem ? `${directusUrl}/assets/${item.imagem}` : null;
---

<Layout title={item.nome} description={item.descricao?.slice(0, 160)} image={imgSrc || undefined}>
  <div class="max-w-container-max-width mx-auto px-gutter py-8">
    <Breadcrumbs items={[
      { label: 'Espaços Culturais', href: '/espacos' },
      { label: item.nome },
    ]} />

    <article class="max-w-3xl mx-auto">
      {imgSrc && (
        <div class="aspect-video rounded-xl overflow-hidden mb-8 bg-surface-container-high">
          <img src={imgSrc} alt={item.nome} class="w-full h-full object-cover" />
        </div>
      )}

      <header class="mb-8">
        <h1 class="font-display text-display-sm md:text-display-lg text-on-surface leading-tight">{item.nome}</h1>
      </header>

      <div class="prose prose-green max-w-none">
        <Fragment set:html={item.descricao} />
      </div>

      <div class="mt-8 space-y-4 bg-surface-container-low rounded-xl p-6">
        {item.endereco && (
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-on-surface-variant">location_on</span>
            <div>
              <span class="font-sans text-label-md text-on-surface">Endereço</span>
              <p class="font-sans text-body-md text-on-surface-variant">{item.endereco}</p>
            </div>
          </div>
        )}
        {item.horario_funcionamento && (
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-on-surface-variant">schedule</span>
            <div>
              <span class="font-sans text-label-md text-on-surface">Horário de Funcionamento</span>
              <p class="font-sans text-body-md text-on-surface-variant">{item.horario_funcionamento}</p>
            </div>
          </div>
        )}
      </div>
    </article>
  </div>
</Layout>
