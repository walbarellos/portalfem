---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import EditalCard from '../components/EditalCard.astro';
import { safeRequest, directus, readItems } from '../lib/directus';

const editais = await safeRequest(
  directus.request(readItems('editais', {
    filter: { status: { _eq: 'published' } },
    sort: ['-data_abertura'],
    fields: ['*', { categoria: ['id', 'nome', 'slug'] }],
  })),
  []
);

const categorias = await safeRequest(
  directus.request(readItems('categorias_editais', {
    fields: ['id', 'nome', 'slug'],
  })),
  []
);

const activeFiltro = Astro.url.searchParams.get('status') || 'todos';
const activeCategoria = Astro.url.searchParams.get('categoria') || '';

const filtered = editais.filter((e) => {
  if (activeFiltro !== 'todos' && e.status_label !== activeFiltro) return false;
  if (activeCategoria) {
    const catObj = typeof e.categoria === 'object' && e.categoria ? e.categoria as { slug: string } : null;
    if (catObj?.slug !== activeCategoria) return false;
  }
  return true;
});

const statusLabels: Record<string, string> = { todos: 'Todos', aberto: 'Abertos', breve: 'Em Análise', encerrado: 'Encerrados' };
const statusColors: Record<string, string> = { aberto: 'bg-primary', breve: 'bg-secondary', encerrado: 'bg-outline' };

const abertos = filtered.filter((e) => e.status_label === 'aberto');
const analise = filtered.filter((e) => e.status_label === 'breve');
const encerrados = filtered.filter((e) => e.status_label === 'encerrado');

function statusConfig(label: string) {
  switch (label) {
    case 'aberto': return { bg: 'bg-primary-container', text: 'text-on-primary-container', label: 'Aberto', bar: 'bg-primary' };
    case 'breve': return { bg: 'bg-secondary-container', text: 'text-on-secondary-container', label: 'Em Análise', bar: 'bg-secondary' };
    case 'encerrado': return { bg: 'bg-surface-container-highest', text: 'text-on-surface-variant', label: 'Encerrado', bar: 'bg-outline' };
    default: return { bg: 'bg-surface-container', text: 'text-on-surface-variant', label: label, bar: 'bg-outline' };
  }
}
---

<Layout title="Editais" description="Editais, chamamentos e oportunidades de financiamento cultural da Fundação de Cultura Elias Mansour">
  <div class="max-w-container-max-width mx-auto px-gutter py-8">

      <PageHero title="Oportunidades para a Cultura" description="Portal do Artista: encontre editais, chamamentos públicos e oportunidades de fomento cultural no Acre." breadcrumbLabel="Editais" />

    <section class="pb-section-gap grid grid-cols-1 lg:grid-cols-12 gap-8">
      <aside class="lg:col-span-3 flex flex-col gap-8">
        <div class="bg-surface-container-lowest rounded-xl p-6 border border-outline-variant/50">
          <h3 class="font-headline-md text-headline-md text-on-surface mb-6">Programas</h3>
          <ul class="flex flex-col gap-2">
            <li>
              <a href="/editais" class={`block w-full px-4 py-3 rounded-lg font-label-md text-label-md transition-colors ${!activeCategoria ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:bg-surface-container'}`}>
                Todos os Programas
              </a>
            </li>
            {categorias.length > 0 ? categorias.map((cat) => {
              const isActive = activeCategoria === cat.slug;
              const href = activeFiltro !== 'todos' ? `/editais?categoria=${cat.slug}&status=${activeFiltro}` : `/editais?categoria=${cat.slug}`;
              return (
              <li>
                <a href={href} class={`block w-full px-4 py-3 rounded-lg font-label-md text-label-md transition-colors flex items-center justify-between group ${isActive ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:bg-surface-container'}`}>
                  {cat.nome}
                  {isActive && <span class="material-symbols-outlined text-sm">check</span>}
                  {!isActive && <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>}
                </a>
              </li>
              );
            }) : (
              <li class="px-4 py-3 text-on-surface-variant font-body-md text-body-md">Nenhum programa cadastrado.</li>
            )}
          </ul>
        </div>
      </aside>

      <div class="lg:col-span-9 flex flex-col gap-6">
        <div class="flex flex-col md:flex-row gap-4 items-center justify-between bg-surface-container-lowest p-4 rounded-xl border border-outline-variant/50">
          <div class="relative w-full md:w-96">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant" aria-hidden="true">search</span>
            <input
              id="edital-search"
              aria-label="Filtrar editais por palavra-chave"
              class="w-full pl-10 pr-4 py-3 rounded-lg border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary bg-surface font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/70 transition-all"
              placeholder="Buscar edital, número ou palavra-chave..."
              type="search"
            />
          </div>
          <div class="flex gap-2 overflow-x-auto w-full md:w-auto pb-2 md:pb-0">
            {['todos', 'aberto', 'breve', 'encerrado'].map((f) => {
              const isActive = activeFiltro === f;
              const href = f === 'todos' ? (activeCategoria ? `/editais?categoria=${activeCategoria}` : '/editais') : (activeCategoria ? `/editais?status=${f}&categoria=${activeCategoria}` : `/editais?status=${f}`);
              return isActive ? (
                <span class={`shrink-0 px-4 py-2 rounded-full border border-primary text-primary font-label-md text-label-md bg-surface flex items-center gap-2 cursor-default`}>
                  {f !== 'todos' && <span class={`w-2 h-2 rounded-full ${statusColors[f] || 'bg-outline'}`}></span>}
                  {statusLabels[f] || f}
                </span>
              ) : (
                <a href={href} class={`shrink-0 px-4 py-2 rounded-full border border-outline-variant text-on-surface-variant font-label-md text-label-md hover:bg-surface-container transition-colors flex items-center gap-2`}>
                  {f !== 'todos' && <span class={`w-2 h-2 rounded-full ${statusColors[f] || 'bg-outline'}`}></span>}
                  {statusLabels[f] || f}
                </a>
              );
            })}
          </div>
        </div>

        {editais.length > 0 ? (
          <>
          <div class="flex items-center justify-between">
            <p class="font-body-md text-body-md text-on-surface-variant" id="result-count">Mostrando <strong>{filtered.length}</strong> de <strong>{editais.length}</strong> editais</p>
          </div>
          <div class="flex flex-col gap-8" id="editais-list">
            {activeFiltro === 'todos' ? (
              <>
                {abertos.length > 0 && (
                  <div class="flex flex-col gap-4" data-group="aberto">
                    <div class="flex items-center gap-3">
                      <span class="w-3 h-3 rounded-full bg-primary"></span>
                      <h3 class="font-headline-sm text-headline-sm text-on-surface">Abertos</h3>
                      <span class="text-on-surface-variant font-label-md text-label-md">({abertos.length})</span>
                    </div>
                    {abertos.map((edital) => <EditalCard edital={edital} />)}
                  </div>
                )}
                {analise.length > 0 && (
                  <div class="flex flex-col gap-4" data-group="breve">
                    <div class="flex items-center gap-3">
                      <span class="w-3 h-3 rounded-full bg-secondary"></span>
                      <h3 class="font-headline-sm text-headline-sm text-on-surface">Em Análise</h3>
                      <span class="text-on-surface-variant font-label-md text-label-md">({analise.length})</span>
                    </div>
                    {analise.map((edital) => <EditalCard edital={edital} />)}
                  </div>
                )}
                {encerrados.length > 0 && (
                  <div class="flex flex-col gap-4" data-group="encerrado">
                    <div class="flex items-center gap-3">
                      <span class="w-3 h-3 rounded-full bg-outline"></span>
                      <h3 class="font-headline-sm text-headline-sm text-on-surface">Encerrados</h3>
                      <span class="text-on-surface-variant font-label-md text-label-md">({encerrados.length})</span>
                    </div>
                    {encerrados.map((edital) => <EditalCard edital={edital} />)}
                  </div>
                )}
              </>
            ) : (
              filtered.map((edital) => <EditalCard edital={edital} />)
            )}
          </div>
          </>
        ) : (
          <div class="text-center py-16">
            <span class="material-symbols-outlined text-4xl text-outline">description</span>
            <p class="font-sans text-body-md text-on-surface-variant mt-2">Nenhum edital encontrado.</p>
          </div>
        )}
      </div>
    </section>
  </div>
</Layout>

<script>
  const input = document.querySelector('input[type="text"]');
  const count = document.getElementById('result-count');

  if (input && count) {
    const editaisTotal = count.querySelector('strong:last-child')?.textContent || '0';
    const updateCount = (visible) => {
      count.innerHTML = `Mostrando <strong>${visible}</strong> de <strong>${editaisTotal}</strong> editais`;
    };

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      const cards = document.querySelectorAll('[data-search]');
      const groups = document.querySelectorAll('[data-group]');
      let visible = 0;

      cards.forEach((card) => {
        const match = !q || card.dataset.search.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      groups.forEach((group) => {
        const hasVisible = Array.from(group.querySelectorAll('[data-search]')).some(
          (c) => (c as HTMLElement).style.display !== 'none'
        );
        (group as HTMLElement).style.display = hasVisible ? '' : 'none';
      });

      updateCount(visible);
    });
  }
</script>
