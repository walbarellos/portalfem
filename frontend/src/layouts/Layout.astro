---
import '@fontsource-variable/space-grotesk';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AcreAcessivel from '../components/AcreAcessivel.astro';
import VLibras from '../components/VLibras.astro';
import BarraAcessibilidade from '../components/BarraAcessibilidade.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { validateEnvironment } from '../lib/env-validation';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

// Validate environment variables on each render (in development)
// In production, this runs once per request
if (import.meta.env.DEV) {
  validateEnvironment();
}

const { title, description, image } = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
const siteName = 'FEM - Fundação de Cultura Elias Mansour';
const defaultDesc = 'Portal oficial da Fundação de Cultura Elias Mansour';
const ogImage = image || `${siteUrl}/og-default.jpg`;
---

<!DOCTYPE html>
<html lang="pt-BR" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || defaultDesc} />
    <meta name="theme-color" content="#00450d" />

    <meta property="og:title" content={title ? `${title} | ${siteName}` : siteName} />
    <meta property="og:description" content={description || defaultDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "GovernmentOrganization",
      "name": "Funda\u00e7\u00e3o de Cultura Elias Mansour",
      "alternateName": "FEM",
      "description": "Portal oficial da Funda\u00e7\u00e3o de Cultura Elias Mansour - FEM, Governo do Estado do Acre",
      "url": "https://femcultura.ac.gov.br",
      "logo": "https://femcultura.ac.gov.br/assets/logos/fem-horizontal.png",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Rua Benjamin Constant, 1234",
        "addressLocality": "Rio Branco",
        "addressRegion": "AC",
        "addressCountry": "BR"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "(68) 3223-1234",
        "contactType": "customer service",
        "email": "comunicacao@fem.ac.gov.br"
      },
      "sameAs": [
        "https://instagram.com/fem.ac",
        "https://facebook.com/fem.ac",
        "https://youtube.com/@femacre"
      ]
    }
    </script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />

    <title>{title ? `${title} | ${siteName}` : siteName}</title>

    <style>
      @font-face {
        font-family: 'Geist';
        src: url('/fonts/Geist-Variable.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist';
        src: url('/fonts/Geist-Regular.woff2') format('woff2');
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist';
        src: url('/fonts/Geist-Medium.woff2') format('woff2');
        font-weight: 500;
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist';
        src: url('/fonts/Geist-SemiBold.woff2') format('woff2');
        font-weight: 600;
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist';
        src: url('/fonts/Geist-Bold.woff2') format('woff2');
        font-weight: 700;
        font-display: swap;
      }
      .hero-overlay {
        background: linear-gradient(to top, rgba(25, 29, 23, 0.9) 0%, rgba(25, 29, 23, 0.3) 50%, rgba(25, 29, 23, 0.1) 100%);
      }
      .card-inner-glow {
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.15);
      }
      .soft-elevation {
        box-shadow: 0 10px 40px -10px rgba(0, 69, 13, 0.08);
      }
      [data-reveal] {
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
      }
      @media (prefers-reduced-motion: no-preference) {
        [data-reveal] {
          opacity: 0;
          transform: translateY(24px);
        }
        [data-reveal].revealed {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }
      .img-shimmer {
        background: linear-gradient(90deg, #e0e4db 25%, #ecefe6 50%, #e0e4db 75%);
        background-size: 200% 100%;
        animation: shimmer 1.8s ease-in-out infinite;
      }
      :focus-visible {
        outline: 2px solid #00450d;
        outline-offset: 2px;
      }
      .high-contrast {
        --color-primary: #002200;
        --color-on-primary: #ffffff;
        --color-primary-container: #003d00;
        --color-on-primary-container: #ffffff;
        --color-secondary: #1a1a1a;
        --color-on-secondary: #ffffff;
        --color-surface: #ffffff;
        --color-on-surface: #000000;
        --color-on-surface-variant: #1a1a1a;
        --color-outline: #000000;
        --color-error: #cc0000;
        --color-on-error: #ffffff;
        --color-surface-container-lowest: #ffffff;
        --color-surface-container-low: #f0f0f0;
        --color-surface-container: #e8e8e8;
        --color-surface-container-high: #dcdcdc;
        --color-surface-container-highest: #cccccc;
        --color-background: #ffffff;
        --color-on-background: #000000;
      }
      .high-contrast a {
        text-decoration: underline;
      }
      .high-contrast a:hover {
        text-decoration: none;
      }
      .high-contrast button,
      .high-contrast [role="button"] {
        border: 2px solid currentColor;
      }
      .high-contrast img {
        filter: contrast(1.2);
      }
    </style>
  </head>
  <body class="bg-background text-on-background font-sans antialiased min-h-screen flex flex-col">
    <BarraAcessibilidade />
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-12 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-primary focus:text-on-primary focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-white">
      Pular para o conteudo principal
    </a>
    <Header />
    <main id="main-content" tabindex="-1" class="flex-grow pt-[108px] focus:outline-none">
      <slot />
    </main>
    <Footer />
    <VLibras />
    <AcreAcessivel />
    <CookieConsent />
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) e.target.classList.add('revealed');
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
