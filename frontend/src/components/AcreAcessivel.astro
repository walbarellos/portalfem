---
/**
 * Acre Acessível — Widget de Acessibilidade
 * 
 * Carrega o widget com mascote Capi, leitor de voz, controles visuais.
 * VLibras é gerenciado separadamente pelo componente VLibras.astro
 * para garantir visibilidade direta do botão de Libras na tela.
 */
---

<script>
  // Importação e integração nativa do widget ao bundler do Astro (Vite)
  import '../acre-acessivel/widget/index.ts';

  // Configuração global para o backend do leitor de voz
  // @ts-ignore
  window.AcreAcessivelConfig = { backendUrl: 'http://localhost:8001' };

  // O script do Astro (type="module") roda após o DOM estar pronto.
  // @ts-ignore
  if (window.AcreAcessivel) {
    // Inicializa o widget desativando a injeção duplicada de libras (já tratada no VLibras.astro)
    // @ts-ignore
    window.AcreAcessivel.init({ libras: false });
  }
</script>
