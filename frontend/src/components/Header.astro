---
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/institucional', label: 'A FEM' },
  { href: '/editais', label: 'Editais' },
  { href: '/noticias', label: 'Notícias' },
  { href: '/eventos', label: 'Eventos' },
  { href: '/espacos', label: 'Espaços' },
  { href: '/servicos', label: 'Serviços' },
  { href: '/ouvidoria', label: 'Ouvidoria' },
];
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="main-header" class="bg-surface/80 backdrop-blur-md fixed top-0 w-full z-50 border-b border-outline-variant/30 transition-transform duration-300">
  <div class="flex items-center justify-between px-gutter py-4 max-w-container-max-width mx-auto">
    <a href="/" class="hover:opacity-80 transition-opacity">
      <img src="/assets/logos/fem-horizontal.png" alt="FEM - Fundação de Cultura Elias Mansour" class="h-10 w-auto object-contain" />
    </a>

    <nav aria-label="Main navigation" class="hidden md:flex gap-8 items-center">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`font-label-md text-label-md transition-all ${
            isActive(item.href)
              ? 'text-primary border-b-2 border-primary pb-1'
              : 'text-on-surface-variant hover:text-primary'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a href="/busca" aria-label="Buscar no portal" class="text-on-surface-variant hover:text-primary transition-all hover:scale-[1.05]">
        <span class="material-symbols-outlined" aria-hidden="true">search</span>
      </a>
      <button id="menu-toggle" aria-label="Abrir menu" aria-expanded="false" class="md:hidden text-on-surface-variant">
        <span id="menu-icon" class="material-symbols-outlined" aria-hidden="true">menu</span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-outline-variant/30 px-gutter py-4 bg-surface">
    <nav class="flex flex-col gap-3">
      <a href="/" class="text-on-surface-variant hover:text-primary transition-colors font-label-md text-label-md">Início</a>
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`font-label-md text-label-md transition-colors ${
            isActive(item.href) ? 'text-primary font-semibold' : 'text-on-surface-variant hover:text-primary'
          }`}
        >
          {item.label}
        </a>
      ))}
      <a href="/busca" class="text-on-surface-variant hover:text-primary transition-colors font-label-md text-label-md">Buscar</a>
    </nav>
  </div>
</header>

<script>
  let scrollInitialized = false;
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('main-header');
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');

    if (!scrollInitialized && header) {
      scrollInitialized = true;
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          header.classList.add('shadow-sm');
          header.style.backgroundColor = 'rgba(247, 251, 241, 0.95)';
        } else {
          header.classList.remove('shadow-sm');
          header.style.backgroundColor = '';
        }
      });
    }

    function closeMenu() {
      if (menu && toggle && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Abrir menu');
        if (icon) icon.textContent = 'menu';
        document.body.style.overflow = '';
      }
    }

    if (toggle && menu && icon) {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        toggle.setAttribute('aria-label', expanded ? 'Abrir menu' : 'Fechar menu');
        icon.textContent = expanded ? 'menu' : 'close';
        menu.classList.toggle('hidden');
        document.body.style.overflow = expanded ? '' : 'hidden';
        if (!expanded) {
          const firstLink = menu.querySelector('a');
          if (firstLink) firstLink.focus();
        } else {
          toggle.focus();
        }
      });

      menu.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { closeMenu(); toggle.focus(); return; }
        if (e.key === 'Tab') {
          const focusable = menu.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])');
          if (!focusable.length) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault(); last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault(); first.focus();
          }
        }
      });

      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    }

    document.addEventListener('click', (e) => {
      if (menu && !menu.classList.contains('hidden') && !header.contains(e.target)) {
        closeMenu();
      }
    });
  });
</script>
