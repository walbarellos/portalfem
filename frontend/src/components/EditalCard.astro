---
import type { Edital } from '../schemas/directus';
import { safeFormatDate } from '../lib/date-utils';

export interface Props {
  edital: any;
}

const { edital } = Astro.props as Props;

const statusConfig = (label: string) => {
  switch (label) {
    case 'aberto': return { bg: 'bg-primary-container', text: 'text-on-primary-container', label: 'Aberto', bar: 'bg-primary' };
    case 'breve': return { bg: 'bg-secondary-container', text: 'text-on-secondary-container', label: 'Em Análise', bar: 'bg-secondary' };
    case 'encerrado': return { bg: 'bg-surface-container-highest', text: 'text-on-surface-variant', label: 'Encerrado', bar: 'bg-outline' };
    default: return { bg: 'bg-surface-container', text: 'text-on-surface-variant', label: label, bar: 'bg-outline' };
  }
};

const sc = statusConfig(edital.status_label);
const catObj = typeof edital.categoria === 'object' && edital.categoria ? edital.categoria : null;
const catNome = catObj ? (catObj as { nome: string }).nome : null;
const isEncerrado = edital.status_label === 'encerrado';
const searchText = [edital.titulo, edital.numero, edital.resumo || '', catNome || ''].filter(Boolean).join(' ').toLowerCase();
---

<article class={`bg-surface-container-lowest border border-outline-variant rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col md:flex-row gap-6 items-start relative group ${isEncerrado ? 'opacity-80' : ''}`} data-search={searchText}>
  <div class={`absolute left-0 top-6 bottom-6 w-1 ${sc.bar} rounded-r-full ${isEncerrado ? 'opacity-40' : ''}`}></div>
  <div class="flex-1 flex flex-col gap-3">
    <div class="flex flex-wrap items-center gap-3">
      <span class={`px-3 py-1 ${sc.bg} ${sc.text} rounded-full font-label-md text-[12px] uppercase tracking-wider`}>{sc.label}</span>
      <span class="font-label-md text-label-md text-on-surface-variant">
        {edital.status_label === 'aberto' ? 'Edital' : 'Chamamento'}
        {edital.numero ? ` Nº ${edital.numero}` : ''}
      </span>
      {catNome && <span class="px-2 py-1 bg-surface-container text-on-surface-variant rounded-md font-label-md text-[12px]">{catNome}</span>}
    </div>
    <a href={`/editais/${edital.id}`}>
      <h2 class="font-headline-lg-mobile md:font-headline-md text-headline-lg-mobile md:text-headline-md text-on-surface group-hover:text-primary transition-colors">{edital.titulo}</h2>
    </a>
    {edital.resumo && (
      <p class="font-body-md text-body-md text-on-surface-variant line-clamp-2 max-w-3xl">{edital.resumo}</p>
    )}
    {edital.data_abertura && edital.data_encerramento && (
      <div class="flex flex-wrap items-center gap-6 mt-2 text-on-surface-variant font-label-md text-label-md">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-xl" aria-hidden="true">calendar_today</span>
          <span>Inscrições: {safeFormatDate(edital.data_abertura)} a {safeFormatDate(edital.data_encerramento)}</span>
        </div>
      </div>
    )}
  </div>
  <div class="w-full md:w-auto flex md:flex-col gap-3 justify-end shrink-0 md:pl-6 md:border-l md:border-outline-variant/30">
    {edital.status_label === 'aberto' ? (
      <>
        <a href={`/editais/${edital.id}`} class="flex-1 md:flex-none flex items-center justify-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-xl font-label-md text-label-md hover:scale-[1.02] hover:bg-primary-container transition-all shadow-sm">
          <span class="material-symbols-outlined" aria-hidden="true">edit_document</span>
          Inscrever-se
        </a>
        {edital.pdf_edital && (
          <a href={`/api/file/${edital.pdf_edital}`} target="_blank" rel="noopener noreferrer" class="flex-1 md:flex-none flex items-center justify-center gap-2 bg-surface text-secondary border border-secondary/30 px-6 py-3 rounded-lg font-label-md text-label-md hover:bg-secondary-container hover:text-on-secondary-container transition-colors">
            <span class="material-symbols-outlined" aria-hidden="true">download</span>
            Edital PDF
          </a>
        )}
      </>
    ) : (
      <a href={`/editais/${edital.id}`} class="flex-1 md:flex-none flex items-center justify-center gap-2 bg-surface text-secondary border border-secondary/30 px-6 py-3 rounded-lg font-label-md text-label-md hover:bg-secondary-container hover:text-on-secondary-container transition-colors">
        <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
        Ver Resultados
      </a>
    )}
  </div>
</article>
