---
import type { ServicoSistema } from '../schemas/directus';

export interface Props {
  servicos: ServicoSistema[];
}

const { servicos } = Astro.props;

const iconMap: Record<string, string> = {
  'Cadastro Cultural': 'app_registration',
  'Solicitar Espaço': 'event_seat',
  'Parecerista': 'rate_review',
  'Transparência': 'visibility',
};

const colorMap: Record<string, { bg: string; icon: string; ring: string }> = {
  'Cadastro Cultural': { bg: 'bg-emerald-500/10', icon: 'text-emerald-600', ring: 'group-hover:ring-emerald-500/30' },
  'Solicitar Espaço': { bg: 'bg-amber-500/10', icon: 'text-amber-600', ring: 'group-hover:ring-amber-500/30' },
  'Parecerista': { bg: 'bg-violet-500/10', icon: 'text-violet-600', ring: 'group-hover:ring-violet-500/30' },
  'Transparência': { bg: 'bg-sky-500/10', icon: 'text-sky-600', ring: 'group-hover:ring-sky-500/30' },
};
---

<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
  {servicos.map((servico) => {
    const icon = iconMap[servico.titulo] || 'settings';
    const color = colorMap[servico.titulo] || { bg: 'bg-primary-container/20', icon: 'text-primary', ring: 'group-hover:ring-primary/30' };
    return (
      <a
        href={servico.url}
        target="_blank"
        rel="noopener noreferrer"
        class={`group bg-surface-container-lowest rounded-2xl border border-outline-variant/20 p-8 text-center hover:shadow-lg hover:shadow-primary/5 hover:border-transparent hover:-translate-y-1 transition-all duration-300 ring-1 ring-transparent ${color.ring}`}
      >
        <div class={`h-14 w-14 mx-auto mb-5 rounded-2xl ${color.bg} flex items-center justify-center transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3`}>
          <span class={`material-symbols-outlined text-3xl ${color.icon}`}>{icon}</span>
        </div>
        <h3 class="font-display text-headline-md text-on-surface group-hover:text-primary transition-colors">{servico.titulo}</h3>
        {servico.descricao && (
          <p class="font-sans text-body-md text-on-surface-variant mt-2 leading-relaxed">{servico.descricao}</p>
        )}
        <div class="mt-5 inline-flex items-center gap-1.5 text-label-md font-label-md text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <span>Acessar</span>
          <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
        </div>
      </a>
    );
  })}
</div>
