---
export interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function pageUrl(page: number): string {
  const separator = baseUrl.includes('?') ? '&' : '?';
  return `${baseUrl}${separator}page=${page}`;
}

const range: number[] = [];
const showPages = 5;
const start = Math.max(1, currentPage - Math.floor(showPages / 2));
const end = Math.min(totalPages, start + showPages - 1);
for (let i = start; i <= end; i++) range.push(i);
---

{totalPages > 1 && (
  <nav class="flex justify-center items-center gap-2 font-label-md text-label-md" aria-label="Paginação">
    {currentPage > 1 ? (
      <a href={pageUrl(currentPage - 1)} class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant hover:bg-surface-container-highest transition-colors" aria-label="Página anterior">
        <span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>
      </a>
    ) : (
      <span class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant opacity-50" aria-disabled="true" aria-hidden="true">
        <span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>
      </span>
    )}
    {start > 1 && (
      <>
        <a href={pageUrl(1)} class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant hover:bg-surface-container-highest transition-colors" aria-label="Página 1">1</a>
        {start > 2 && <span class="text-on-surface-variant px-2" aria-hidden="true">...</span>}
      </>
    )}
    {range.map((page) => (
      <a
        href={pageUrl(page)}
        class={`w-10 h-10 flex items-center justify-center rounded-full transition-colors ${
          page === currentPage
            ? 'bg-primary text-on-primary shadow-sm'
            : 'text-on-surface-variant hover:bg-surface-container-highest'
        }`}
        aria-current={page === currentPage ? 'page' : undefined}
      >
        {page}
      </a>
    ))}
    {end < totalPages && (
      <>
        {end < totalPages - 1 && <span class="text-on-surface-variant px-2" aria-hidden="true">...</span>}
        <a href={pageUrl(totalPages)} class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant hover:bg-surface-container-highest transition-colors" aria-label={`Página ${totalPages}`}>{totalPages}</a>
      </>
    )}
    {currentPage < totalPages ? (
      <a href={pageUrl(currentPage + 1)} class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant hover:bg-surface-container-highest transition-colors" aria-label="Próxima página">
        <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
      </a>
    ) : (
      <span class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant opacity-50" aria-disabled="true" aria-hidden="true">
        <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
      </span>
    )}
  </nav>
)}
