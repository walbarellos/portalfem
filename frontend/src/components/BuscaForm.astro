---
export interface Props {
  query: string;
}

const { query } = Astro.props;
---

<form action="/busca" method="GET" role="search" class="w-full">
  <div class="relative">
    <label for="busca-input" class="sr-only">Buscar no portal</label>
    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant" aria-hidden="true">search</span>
    <input
      id="busca-input"
      type="search"
      name="q"
      value={query}
      placeholder="Buscar notícias, editais, eventos..."
      class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface font-sans text-body-md text-on-surface placeholder:text-on-surface-variant/70 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
      autocomplete="off"
    />
  </div>
</form>
