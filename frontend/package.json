{
  "name": "fem-portal-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/node": "^9.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@astrojs/tailwind": "^6.0.0",
    "@directus/sdk": "^16.0.0",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^5.0.0",
    "date-fns": "^3.0.0",
    "geist": "^1.7.1",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
