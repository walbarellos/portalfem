# Database
DB_DATABASE=fem_directus
DB_USER=fem_admin
DB_PASSWORD=coloque-a-senha-aqui

# Redis
REDIS_PASSWORD=coloque-a-senha-redis-aqui

# Directus Keys (gerar com: openssl rand -base64 32)
DIRECTUS_KEY=change-this-to-64-random-chars
DIRECTUS_SECRET=change-this-to-32-random-chars

# Admin User
ADMIN_EMAIL=admin@femcultura.ac.gov.br
ADMIN_PASSWORD=coloque-a-senha-admin-aqui

# ATENÇÃO: O arquivo .env REAL contém senhas em texto plano.
# Considere usar variáveis de ambiente do SO ou um cofre de senhas
# em produção (ex: HashiCorp Vault, AWS Secrets Manager, Windows Credential Manager).

# Timezone
TZ=America/Rio_Branco
